  "description": "xMessage Server — Mac-side bridge for the Xcelerate iMessage integration (fork of BlueBubbles).",
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "{src,test,mocks}/**/*.{json,css,scss,md}": [
      "prettier --config ./.prettierrc --ignore-path ./.prettierignore --write"
    ],
    "{src,test,mocks}/**/*.{js,ts,tsx}": [
      "prettier --config ./.prettierrc --ignore-path ./.prettierignore --write",
      "eslint --ext=jsx,js,ts,tsx --fix src"
    ]
  },
