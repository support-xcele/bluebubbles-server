    "blurhash": "^1.1.3",
    "byte-base64": "^1.1.0",
    "compare-versions": "^3.6.0",
    "conditional-decorator": "^0.1.7",
    "crypto-js": "^4.0.0",
    "electron-log": "^4.4.7",
    "electron-updater": "^5.3.0",
    "find-process": "^1.4.7",
    "firebase-admin": "^12.2.0",
